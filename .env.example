OPENAI_API_KEY=sk-proj-your-key
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Use "openai" for model answers or "extractive" to answer from retrieved chunks
# without calling OpenAI.
AI_PROVIDER=openai

# PostgreSQL with pgvector. Leave blank to use the demo retriever.
DATABASE_URL=postgres://user:password@localhost:5432/tmd_chat
RAG_TABLE=rag_documents
RAG_MATCH_COUNT=6

# Use the local TF-IDF vector DB from data/synop_vector_db.
# If DATABASE_URL is blank and this folder exists, the app uses it automatically.
RAG_PROVIDER=local-all
PYTHON_BIN=python3
